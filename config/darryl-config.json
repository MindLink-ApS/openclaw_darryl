{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": ["https://openclaw-darryl.onrender.com"],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "userTimezone": "America/Chicago",
      "skipBootstrap": true,
      "thinkingDefault": "low",
      "heartbeat": {
        "every": "30m",
        "activeHours": {
          "start": "06:00",
          "end": "19:00",
          "timezone": "America/Chicago"
        },
        "target": "none",
        "lightContext": false
      }
    },
    "list": [
      {
        "id": "emma",
        "default": true,
        "name": "Emma Jones",
        "workspace": "/app/workspace",
        "model": {
          "primary": "claude-sonnet-4-6"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "provider": "brave"
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${HOOKS_TOKEN}",
    "presets": ["gmail"],
    "gmail": {
      "account": "${EMMA_GMAIL_ADDRESS}",
      "label": "INBOX"
    }
  },
  "plugins": {
    "slots": {
      "memory": "darryl-mem0"
    },
    "entries": {
      "darryl-leads": {
        "enabled": true,
        "config": {
          "dbPath": "/data/.openclaw/darryl/leads.db"
        }
      },
      "darryl-email": {
        "enabled": true,
        "config": {
          "host": "smtp.gmail.com",
          "port": 587,
          "secure": false,
          "user": "${EMMA_GMAIL_ADDRESS}",
          "pass": "${EMMA_GMAIL_APP_PASSWORD}",
          "from": "Emma Jones <${EMMA_GMAIL_ADDRESS}>"
        }
      },
      "darryl-mem0": {
        "enabled": true,
        "config": {
          "dataDir": "/data/.openclaw/mem0",
          "userId": "darryl",
          "autoRecall": true,
          "autoCapture": true,
          "openaiApiKey": "${OPENAI_API_KEY}"
        }
      }
    }
  },
  "cron": {
    "enabled": true
  }
}
