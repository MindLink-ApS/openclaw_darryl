{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "list": [
      {
        "id": "scout",
        "default": true,
        "name": "Scout",
        "model": {
          "primary": "claude-sonnet-4-5-20250514"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "provider": "brave"
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": true,
    "presets": ["gmail"],
    "gmail": {
      "account": "${SCOUT_GMAIL_ADDRESS}",
      "label": "INBOX"
    }
  },
  "plugins": {
    "entries": {
      "darryl-leads": {
        "enabled": true,
        "config": {
          "dbPath": "/data/.openclaw/darryl/leads.db"
        }
      },
      "darryl-email": {
        "enabled": true,
        "config": {
          "host": "smtp.gmail.com",
          "port": 587,
          "secure": false,
          "user": "${SCOUT_GMAIL_ADDRESS}",
          "pass": "${SCOUT_GMAIL_APP_PASSWORD}",
          "from": "Scout <${SCOUT_GMAIL_ADDRESS}>"
        }
      },
      "darryl-mem0": {
        "enabled": true,
        "config": {
          "dataDir": "/data/.openclaw/mem0",
          "userId": "darryl",
          "autoRecall": true,
          "autoCapture": true,
          "openaiApiKey": "${OPENAI_API_KEY}"
        }
      }
    }
  },
  "cron": {
    "enabled": true
  }
}
