{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": ["https://openclaw-darryl.onrender.com"],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "userTimezone": "America/Chicago",
      "skipBootstrap": true,
      "thinkingDefault": "xhigh",
      "heartbeat": {
        "every": "30m",
        "activeHours": {
          "start": "04:00",
          "end": "24:00",
          "timezone": "America/Chicago"
        },
        "target": "none",
        "lightContext": true
      }
    },
    "list": [
      {
        "id": "emma",
        "default": true,
        "name": "Emma Jones",
        "workspace": "/app/workspace",
        "model": {
          "primary": "x-ai/grok-4.20"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "provider": "brave"
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${HOOKS_TOKEN}",
    "presets": ["gmail"],
    "gmail": {
      "account": "${EMMA_GMAIL_ADDRESS}",
      "label": "INBOX",
      "topic": "projects/mail-project-489210/topics/gmail-watch-emma",
      "pushToken": "${GMAIL_PUSH_TOKEN}"
    }
  },
  "plugins": {
    "slots": {
      "memory": "darryl-mem0"
    },
    "entries": {
      "darryl-leads": {
        "enabled": true,
        "config": {
          "dbPath": "/data/.openclaw/darryl/leads.db"
        }
      },
      "darryl-email": {
        "enabled": true,
        "config": {
          "host": "smtp.gmail.com",
          "port": 587,
          "secure": false,
          "user": "${EMMA_GMAIL_ADDRESS}",
          "pass": "${EMMA_GMAIL_APP_PASSWORD}",
          "from": "Emma Jones <${EMMA_GMAIL_ADDRESS}>"
        }
      },
      "darryl-mem0": {
        "enabled": true,
        "config": {
          "dataDir": "/data/.openclaw/mem0",
          "userId": "darryl",
          "autoRecall": true,
          "autoCapture": true,
          "openaiApiKey": "${OPENAI_API_KEY}"
        }
      },
      "darryl-apollo": {
        "enabled": true,
        "config": {
          "apiKey": "${APOLLO_API_KEY}",
          "syncMonthlyLimit": 100,
          "asyncPhoneMonthlyLimit": 50,
          "webhookBaseUrl": "https://openclaw-darryl.onrender.com",
          "webhookSecret": "${APOLLO_WEBHOOK_SECRET}",
          "hooksToken": "${HOOKS_TOKEN}",
          "dataDir": "/data/.openclaw/darryl/apollo",
          "leadsDbPath": "/data/.openclaw/darryl/leads.db"
        }
      }
    }
  },
  "cron": {
    "enabled": true
  }
}
